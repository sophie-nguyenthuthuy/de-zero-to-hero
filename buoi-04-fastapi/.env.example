# Copy sang .env và chỉnh cho môi trường của bạn.
# Tất cả biến đều có default trong app/core/config.py — file này chỉ để override.

# App
APP_NAME=DE Lab API
VERSION=1.0.0
DEBUG=false

# Database (reuse de_lab từ Buổi 3)
DB_HOST=localhost
DB_PORT=5432
DB_USER=deuser
DB_PASS=depassword123
DB_NAME=de_lab

# JWT — ĐỔI SECRET_KEY ở production!
SECRET_KEY=de-lab-super-secret-key-change-in-prod-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
